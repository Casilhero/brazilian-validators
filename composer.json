{
  "name": "casilhero/brazilian-validators",
  "description": "Reusable Brazilian validators for PHP projects.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "brazil",
    "validation",
    "cpf",
    "cnpj",
    "laravel"
  ],
  "authors": [
    {
      "name": "Casilhero",
      "email": "opensource@casilhero.com"
    }
  ],
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "pestphp/pest": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Casilhero\\BrazilianValidators\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Casilhero\\BrazilianValidators\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "format": "vendor/bin/pint",
    "format:check": "vendor/bin/pint --test",
    "test": "vendor/bin/pest",
    "test:coverage": "php -d xdebug.mode=coverage vendor/bin/pest --coverage --min=90"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
